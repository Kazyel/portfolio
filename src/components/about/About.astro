---
import Experience from "./Experience.astro";
import MyInfo from "./MyInfo.astro";

import { Image } from "astro:assets";
import InkPaint from "@/assets/ink-paint.png";
import InkPaint2 from "@/assets/ink-paint-2.png";
---

<section id="about-section" class="relative overflow-hidden">
    <div
        class="grid relative min-h-screen grid-cols-6 max-xl:flex max-xl:flex-col max-sm:w-full max-xl:pb-20 xl:p-20 3xl:p-0 bg-off-w"
    >
        <!-- About Me -->
        <div
            id="about-me"
            class="col-span-3 max-xl:pt-20 max-xl:mb-12 flex h-full flex-col xl:items-end items-center justify-center xl:pr-16 2xl:pr-28"
        >
            <MyInfo />
        </div>
        <!-- Experience -->
        <div
            class="col-span-3 xl:pl-12 xl:pr-0 pt-4 px-12 max-xl:pt-10 flex items-center justify-center flex-col xl:max-w-xl 2xl:max-w-2xl h-full z-20"
        >
            <Experience
                year="2024"
                text="Lorem ipsum dolor sit amet consectetur, adipisicing elit. Cumque itaque aliquid labore provident. Officia totam illum commodi, natus sit assumenda, vero facilis recusandae nemo enim nostrum delectus, placeat dolorum suscipit?"
            />
            <Experience
                year="2023"
                text="Lorem ipsum dolor sit amet consectetur, adipisicing elit. Cumque itaque aliquid labore provident. Officia totam illum commodi, natus sit assumenda, vero facilis recusandae nemo enim nostrum delectus, placeat dolorum suscipit?"
            />
            <Experience
                year="2022"
                text="Lorem ipsum dolor sit amet consectetur, adipisicing elit. Cumque itaque aliquid labore provident. Officia totam illum commodi, natus sit assumenda, vero facilis recusandae nemo enim nostrum delectus, placeat dolorum suscipit?"
            />
            <Experience
                year="2021"
                text="Lorem ipsum dolor sit amet consectetur, adipisicing elit. Cumque itaque aliquid labore provident. Officia totam illum commodi, natus sit assumenda, vero facilis recusandae nemo enim nostrum delectus, placeat dolorum suscipit?"
            />
        </div>
    </div>

    <Image
        src={InkPaint2}
        alt="Dragon"
        class="absolute w-[1000px] -bottom-36 -right-28 mix-blend-multiply opacity-50 grayscale max-md:hidden"
    />

    <Image
        src={InkPaint}
        alt="Dragon"
        class="absolute w-[800px] -bottom-36 -left-72 mix-blend-multiply opacity-20 grayscale max-md:hidden"
    />
</section>
