---
import { Image } from "astro:assets";
import ProjectsJSX from "./Projects.tsx";
import RedSakura from "@/assets/imgs/higan.png";
---

<section
  class="snap-start snap-always bg-pattern relative flex min-h-screen w-full section flex-col justify-center overflow-hidden bg-amber-900/10 max-xl:p-10"
>
  <ProjectsJSX client:only="react" />

  {/* {Background Trees} */}
  <div>
    <Image
      src={RedSakura}
      alt="Higan flower"
      width={700}
      height={1000}
      class="absolute bottom-0 left-28 z-10 aspect-square h-[1000px] w-[700px] opacity-40 mix-blend-color-burn max-xl:hidden"
      loading="lazy"
      decoding="async"
    />
    <Image
      src={RedSakura}
      alt="Higan flower"
      width={400}
      height={700}
      class="absolute -bottom-12 -left-40 z-10 h-[700px] w-[400px] -rotate-45 opacity-20 mix-blend-color-burn max-xl:hidden"
      loading="lazy"
      decoding="async"
    />
    <Image
      src={RedSakura}
      alt="Higan flower"
      width={500}
      height={600}
      class="absolute -bottom-20 left-[24rem] z-10 h-[600px] w-[500px] opacity-25 mix-blend-color-burn max-2xl:hidden"
      loading="lazy"
      decoding="async"
    />

    <Image
      src={RedSakura}
      alt="Higan flower"
      width={700}
      height={1100}
      class="absolute bottom-0 right-28 z-10 h-[1100px] w-[700px] scale-x-[-1] opacity-40 mix-blend-color-burn max-xl:hidden"
      loading="lazy"
      decoding="async"
    />
    <Image
      src={RedSakura}
      alt="Higan flower"
      width={400}
      height={700}
      class="absolute -bottom-12 -right-40 z-10 h-[700px] w-[400px] rotate-45 opacity-20 mix-blend-color-burn max-xl:hidden"
      loading="lazy"
      decoding="async"
    />
    <Image
      src={RedSakura}
      alt="Higan flower"
      width={500}
      height={600}
      class="absolute -bottom-20 right-[24rem] z-10 h-[600px] w-[500px] scale-x-[-1] opacity-25 mix-blend-color-burn max-2xl:hidden"
      loading="lazy"
      decoding="async"
    />
  </div>

  <div
    class="absolute bottom-0 left-0 z-10 h-full w-full rounded-lg bg-gradient-to-t from-black/35 to-transparent opacity-100"
  >
  </div>
</section>
