---
import PostgreSvg from "../../public/postgres.svg";
import GitSvg from "../../public/github.svg";
import DockerSvg from "../../public/docker.svg";
import PythonSvg from "../../public/python.svg";
import GoLangSvg from "../../public/go.svg"
import DataSvg from "../../public/data.svg"

import { Skills as SkillsArray } from "../constants/index";
import { Image } from "astro:assets";
import Navbar from "../components/Navbar.tsx";
import Layout from "../layouts/Layout.astro";
import SkillCard from "../components/SkillCard";
---

<Layout title="Kazyel | My Skills">
  <Navbar skillsActive={true} />
  <section
    class="relative flex min-h-screen w-full flex-col items-center justify-center"
  >
    <div
      transition:animate="fade"
      class="mt-16 grid w-[1368px] grid-flow-row grid-cols-4 items-end gap-10"
    >
      {
        SkillsArray.map(({ img, skill, alt, text }) => (
          <SkillCard
            client:load
            img={img}
            skill={skill}
            alt={alt}
            text={text}
          />
        ))
      }
      <div
        class="col-span-2 col-start-3 row-start-1 flex h-full flex-col justify-center gap-1"
      >
        <h3 class="text-2xl font-semibold text-acc-yellow-2">The Basics</h3>
        <div class="pt-6">
          <div class="flex flex-col gap-6">
            <div class="flex items-center gap-3 text-off-w">
              <Image
                src={GitSvg}
                alt="GitHub Logo"
                class="aspect-square w-12 invert"
              />
              <p>GitHub</p>
            </div>
            <div class="flex items-center gap-3 text-off-w">
              <Image
                src={DockerSvg}
                alt="Docker Logo"
                class="aspect-square w-12"
              />
              <p class="">Docker</p>
            </div>
            <div class="flex items-center gap-3 text-off-w">
              <Image
                src={PythonSvg}
                alt="Docker Logo"
                class="aspect-square w-12"
              />
              <p class="">Python</p>
            </div>
          </div>
        </div>
      </div>
      <div class="col-span-2 flex flex-col gap-1 text-off-w">
        <h3 class="text-2xl font-semibold text-acc-yellow-2">
          Learning right now!🔥
        </h3>
        <div class="grid grid-cols-9 justify-center gap-3 pt-6">
          <div class="col-span-3 flex flex-col items-center gap-2">
            <div class="flex w-full items-center gap-2">
              <Image src={GoLangSvg} alt="NextSvg" class="h-8 w-8" />
              <h3 class="font-semibold">GoLang</h3>
            </div>
            <p class="font-extralight">
              Lorem ipsum dolor, sit amet consectetur adipisicing elit. Corporis
              non ipsa dolore repudiandae alias mollitia at nostrum quae quam
              quidem illo placeat, maiores magnam velit enim, ea odio, quasi
              rerum?
            </p>
          </div>
          <div class="col-span-3 flex flex-col items-center gap-2">
            <div class="flex w-full items-center gap-2">
              <Image src={PostgreSvg} alt="NextSvg" class="h-8 w-8" />
              <h3 class="font-semibold">PostgreSQL</h3>
            </div>
            <p class="font-extralight">
              Lorem ipsum dolor, sit amet consectetur adipisicing elit. Corporis
              non ipsa dolore repudiandae alias mollitia at nostrum quae quam
              quidem illo placeat, maiores magnam velit enim, ea odio, quasi
              rerum?
            </p>
          </div>
          <div class="col-span-3 flex flex-col items-center gap-2">
            <div class="flex w-full items-center gap-2">
              <Image src={DataSvg} alt="NextSvg" class="h-8 w-8 invert" />
              <h3 class="font-semibold">Data Structures & Algorithms</h3>
            </div>
            <p class="font-extralight">
              Lorem ipsum dolor, sit amet consectetur adipisicing elit. Corporis
              non ipsa dolore repudiandae alias mollitia at nostrum quae quam
              quidem illo placeat, maiores magnam velit enim, ea odio, quasi
              rerum?
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
