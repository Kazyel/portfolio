---
import Kanagawa from "../../public/kanagawa.png";
import Isa from "../../public/isa.jpg";
import ReactSvg from "../../public/react.svg";
import CssSvg from "../../public/css.svg";
import JSSvg from "../../public/javascript.svg";
import TSSvg from "../../public/typescript.svg";

import { Image } from "astro:assets";
import Navbar from "../components/Navbar.tsx";
import Layout from "../layouts/Layout.astro";
---

<Layout title="Kazyel | About me">
  <Navbar aboutActive={true} />

  <section
    class="relative flex min-h-screen w-full flex-col items-center justify-center overflow-hidden text-center"
  >
    <div
      transition:animate="fade"
      class="mt-16 grid min-h-[768px] min-w-[1368px] grid-cols-10 grid-rows-4"
    >
      <div
        class="col-span-7 row-span-4 flex items-center justify-around gap-12"
      >
        <div class="flex w-[324px] flex-col gap-8">
          <div class="flex justify-center gap-3">
            <h2 class="text-xl font-semibold text-acc-yellow">Yo, it's me!</h2>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="h-7 w-7 text-acc-yellow"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15.75 17.25L12 21m0 0l-3.75-3.75M12 21V3"></path>
            </svg>
          </div>
          <Image
            src={Isa}
            class="aspect-square rounded-[50%] border border-stone-700 object-cover p-2"
            width={324}
            height={324}
            alt="isa linda"
          />
          <p class="text-left text-off-w">
            Lorem ipsum dolor, sit amet consectetur adipisicing elit. Obcaecati
            ullam ad quam nisi, itaque corrupti vitae totam placeat, amet
            voluptatum consequatur repudiandae modi nihil asperiores sapiente,
            ab odio eos. Cum?
          </p>
        </div>
        <div>
          <div
            class="h-[372px relative w-[372px] border-l-4 border-stone-700 py-6 pl-6 text-justify text-off-w"
          >
            <p>
              Lorem ipsum dolor sit amet consectetur, adipisicing elit. Cumque
              itaque aliquid labore provident. Officia totam illum commodi,
              natus sit assumenda, vero facilis recusandae nemo enim nostrum
              delectus, placeat dolorum suscipit?
            </p>
            <div
              class="absolute -left-[10px] -top-1 h-4 w-4 rounded-full bg-stone-700"
            >
            </div>
            <p class="absolute -top-2 font-semibold text-off-w">2023</p>
          </div>
          <div
            class="h-[368px relative w-[368px] border-l-4 border-stone-700 py-6 pl-6 text-justify text-off-w"
          >
            <p>
              Lorem ipsum dolor sit amet consectetur, adipisicing elit. Cumque
              itaque aliquid labore provident. Officia totam illum commodi,
              natus sit assumenda, vero facilis recusandae nemo enim nostrum
              delectus, placeat dolorum suscipit?
            </p>
            <div
              class="absolute -left-[10px] -top-1 h-4 w-4 rounded-full bg-stone-700"
            >
            </div>
            <p class="absolute -top-2 font-semibold text-off-w">2023</p>
          </div>
          <div
            class="h-[368px relative w-[368px] border-l-4 border-stone-700 pl-6 pt-6 text-justify text-off-w"
          >
            <p>
              Lorem ipsum dolor sit amet consectetur, adipisicing elit. Cumque
              itaque aliquid labore provident. Officia totam illum commodi,
              natus sit assumenda, vero facilis recusandae nemo enim nostrum
              delectus, placeat dolorum suscipit?
            </p>
            <div
              class="absolute -left-[10px] -top-1 h-4 w-4 rounded-full bg-stone-700"
            >
            </div>
            <p class="absolute -top-2 font-semibold text-off-w">2023</p>
          </div>
        </div>
      </div>
      <div
        class="col-span-2 row-span-4 flex flex-col items-center justify-center gap-12"
      >
        <Image src={ReactSvg} width={64} height={64} alt="React Icon" />
        <Image src={CssSvg} width={64} height={64} alt="React Icon" />
        <Image src={JSSvg} width={64} height={64} alt="React Icon" />
        <Image src={TSSvg} width={64} height={64} alt="React Icon" />
        <a href="/skills" class="relative cursor-pointer text-off-w"
          ><span
            class="after:ease after:absolute after:bottom-[-2px] after:left-0 after:w-0 after:border-white after:transition-all after:duration-[250ms] hover:after:w-full hover:after:border-b"
            >See more +</span
          >
        </a>
      </div>
    </div>

    <Image
      src={Kanagawa}
      alt="Kanagawa Wave"
      class="absolute bottom-0 -z-10 w-full bg-cover opacity-20 mix-blend-multiply grayscale"
      quality={100}
      width={1920}
      height={100}
    />
  </section>
</Layout>
 ../components/Navbar.tsx
